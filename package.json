{
  "name": "psiflux",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n FRONT,BACK -c cyan,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "cd backend && node --watch index.js",
    "build": "vite build",
    "preview": "vite preview",
    "migrate": "cd backend && node migrate.js",
    "patch-db": "cd backend && node patch_database.js",
    "reset-db": "cd backend && node reset_database.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^1.33.0",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "express-rate-limit": "^8.3.1",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.561.0",
    "openai": "^6.29.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "supertest": "^7.2.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  }
}
